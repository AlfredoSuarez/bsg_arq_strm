# Nunca subas el archivo .env ni pegues esta clave en código.
# Crea una clave personal en OpenRouter y pégala solo en este archivo local.
OPENROUTER_API_KEY=pega_aqui_tu_clave

# Modelo gratuito solicitado para este laboratorio. La disponibilidad, cuota y
# proveedores pueden cambiar; modifica únicamente esta variable si es necesario.
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Metadatos opcionales de atribución en OpenRouter.
OPENROUTER_APP_URL=http://localhost:8501
OPENROUTER_APP_NAME=Clase 3 - Agente MCP E-commerce

# URLs locales de los dos MCP remotos.
DATA_MCP_URL=http://127.0.0.1:8000/mcp
AGENT_MCP_URL=http://127.0.0.1:8001/mcp

# Ventana pedagógica de memoria: conserva el mensaje inicial y los últimos N mensajes.
MEMORY_WINDOW_MESSAGES=8
