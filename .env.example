# Nunca subas el archivo .env ni pegues esta clave en código.
# Crea una clave personal en OpenRouter y pégala solo en este archivo local.
OPENROUTER_API_KEY=pega_aqui_tu_clave

# Modelo gratuito solicitado para este laboratorio. La disponibilidad, cuota y
# proveedores pueden cambiar; modifica únicamente esta variable si es necesario.
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Metadatos opcionales de atribución en OpenRouter.
OPENROUTER_APP_URL=http://localhost:8501
OPENROUTER_APP_NAME=Clase 3 - Agente MCP E-commerce

# URLs locales de los dos MCP remotos.
DATA_MCP_URL=http://127.0.0.1:8000/mcp
AGENT_MCP_URL=http://127.0.0.1:8001/mcp

# Ventana pedagógica de memoria: conserva el mensaje inicial y los últimos N mensajes.
MEMORY_WINDOW_MESSAGES=8

# ---------------------------------------------------------------------------
# Backend de datos. Reglas de selección (ver db.py):
#   - DB_BACKEND=supabase  -> fuerza Supabase (requiere DATABASE_URL)
#   - DB_BACKEND=sqlite     -> fuerza SQLite local
#   - sin DB_BACKEND        -> si hay DATABASE_URL usa Supabase; si no, SQLite (auto)
# En despliegue basta definir DATABASE_URL: la app usa Supabase sin caer a SQLite.
DB_BACKEND=sqlite

# Cadena de conexión de Supabase (activa Supabase aunque no definas DB_BACKEND).
# Supabase -> Project Settings -> Database -> Connection string.
# Para apps con muchas conexiones usa el pooler (puerto 6543); para cargas y
# migraciones usa la conexión directa (puerto 5432). Nunca subas el .env real.
# DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# Claves públicas de Supabase (opcionales; para clientes tipo dashboard con RLS).
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_ANON_KEY=pega_aqui_tu_anon_o_publishable_key
